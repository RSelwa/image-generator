  "emulators": {
    "ui": {
      "enabled": true
    },
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "pubsub": {
      "port": 8085
    },
    "database": {
      "port": 9000
    },
    "singleProjectMode": true
  },
  "database": {
    "rules": "rules/src/database.rules.json"
  },
  "firestore": {
    "database": "(default)",
    "location": "eur3",
    "rules": "./rules/src/firestore.rules"
  },
  "storage": {
    "rules": "rules/src/storage.rules"
  }
