{
  "name": "@repo/create-user-document",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "files": [
    ".env.*",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "compile": "tsc --noEmit",
    "lint": "biome check",
    "check-circular": "madge --circular --extensions ts ./src --ts-config ./tsconfig.json",
    "test": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 vitest run --coverage",
    "test:emulator": "firebase emulators:exec --project tiktok-generator-fa261 'vitest run --coverage'",
    "clean": "del-cli dist isolate tsconfig.tsbuildinfo coverage",
    "deploy": "firebase deploy --project tiktok-generator-fa261",
    "emulate": "firebase emulators:start --project tiktok-generator-fa261",
    "login": "firebase login"
  },
  "dependencies": {
    "@firebase/firestore": "^4.10.0",
    "@google-cloud/functions-framework": "^4.0.0",
    "@repo/common": "workspace:*",
    "@repo/providers": "workspace:*",
    "@repo/schemas": "workspace:*",
    "cors": "^2.8.5",
    "del-cli": "^6.0.0",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.3.2",
    "nocache": "^4.0.0"
  },
  "devDependencies": {
    "@codecompose/typescript-config": "^2.2.0",
    "@faker-js/faker": "^10.1.0",
    "@types/cors": "^2.8.19",
    "@types/node": "^22.10.10",
    "@vitest/coverage-v8": "^3.2.4",
    "del-cli": "^6.0.0",
    "firebase-functions-test": "^3.4.1",
    "madge": "^8.0.0",
    "tsdown": "^0.15.6",
    "typescript": "^5.9.0",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
