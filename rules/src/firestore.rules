rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }

    function onlyUpdatesFields(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function isUpdateUsersRights() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['rights'])
    }

     function isDocOwner(id) {
      return request.auth.uid == id || request.auth.uid == resource.data.ownerId || request.auth.uid == resource.data.owner_id;
    }

    function noUpdatesOnFields(fields) {
      return (!request.resource.data.diff(resource.data).affectedKeys().hasAny(fields))
    }
    
    function signedInIconograph() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/rights/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/rights/$(request.auth.uid)).data.right == "iconograph";
    }

    function signedInAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/rights/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/rights/$(request.auth.uid)).data.right == "admin";
    }

   match /{document=**} {
      allow read, write: if signedInAdmin();
    }

    match /rights/{right} {
      allow write: if signedInAdmin();
     
      allow read: if isDocOwner(right);
    } 

    match /users/{user} {
      allow create: if isSignedIn();

      allow update: if isDocOwner(user) || signedInAdmin();
      allow delete: if request.auth.uid == user;
     
      allow read: if true;
    } 

    match /games/{game} {
      allow create, update: if signedInIconograph();
      allow write: if signedInAdmin();

      allow read: if true;

      match /spherical/{spherical} {
        allow write: if signedInAdmin();
        allow create, update: if signedInIconograph();

        allow read: if true;
      }

      match /flat/{flatId} {
        allow write: if signedInAdmin();
        allow create, update: if signedInIconograph();

        allow read: if true;
      }

      match /maps/{map} {
        allow write: if signedInAdmin();
        allow create, update: if signedInIconograph();

        allow read: if true;
      }
    }

    match /spherical/{spherical} {
      allow write: if signedInAdmin();
      allow create, update: if signedInIconograph();

      allow read: if true;
    }


    // Seed collection - admin can write, anyone can read
    match /seed/{seedId} {
      allow write: if signedInAdmin();
      allow read: if true;
    }

    // Lobbies collection
    match /lobbies/{lobbyId} {
      // function isLobbyPlayer() {
      //   return isSignedIn() && request.auth.uid in resource.data.players.map(p => p.uid);
      // }

      // function isLobbyPlayerIncoming() {
      //   return isSignedIn() && request.auth.uid in request.resource.data.players.map(p => p.uid);
      // }

      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update:  if isSignedIn();
      // allow update: if isLobbyPlayer() || isLobbyPlayerIncoming();
      allow delete: if signedInAdmin();

      // RoundAnswers subcollection
      match /roundAnswers/{answerId} {
        //function isParentLobbyPlayer() {
        //  return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/lobbies/$(lobbyId)).data.players.map(p => p.uid);
        //}

        allow create, read, update: if isSignedIn();
        // allow create: if isSignedIn() && isParentLobbyPlayer();
        // allow read, update: if isParentLobbyPlayer();
        allow delete: if signedInAdmin();
      }
    }

    // CollectionGroup queries
    match /{path=**}/spherical/{spherical} {
      allow write: if signedInAdmin();
      allow create, update: if signedInIconograph();

      allow read: if true;
    }

    match /{path=**}/flat/{flatId} {
      allow write: if signedInAdmin();
      allow create, update: if signedInIconograph();

      allow read: if true;
    }

    match /{path=**}/maps/{map} {
      allow write: if signedInAdmin();
      allow create, update: if signedInIconograph();

      allow read: if true;
    }

    match /{path=**}/roundAnswers/{map} {
      allow write: if signedInAdmin();
      allow create, update: if signedInIconograph();

      allow read: if true;
    }

    

  }
}

