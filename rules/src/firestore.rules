rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }

    function onlyUpdatesFields(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function isUpdateUsersRights() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['rights'])
    }

     function isDocOwner(id) {
      return request.auth.uid == id || request.auth.uid == resource.data.ownerId || request.auth.uid == resource.data.owner_id;
    }

    function noUpdatesOnFields(fields) {
      return (!request.resource.data.diff(resource.data).affectedKeys().hasAny(fields))
    }
    
    function signedInAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rights == "admin";
    }

    match /users/{user} {
      allow create: if isSignedIn();

      allow update: if (request.auth.uid == user && !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['rights'])) || signedInAdmin();
      allow  delete: if request.auth.uid == user;
     
      allow read: if true;
    } 

    match /games/{game} {
      allow write: if signedInAdmin() && isSignedIn();
      allow read: if true;

      match /spherical/{spherical} {
        allow write: if signedInAdmin() && isSignedIn();
        allow read: if true;
        }

      match /maps/{map} {
        allow write: if signedInAdmin() && isSignedIn();
        allow read: if true;
      }
    }

    // CollectionGroup queries
    match /{path=**}/spherical/{spherical} {
      allow write: if signedInAdmin() && isSignedIn();
      allow read: if true;
    } 
    match /{path=**}/maps/{map} {
      allow write: if signedInAdmin() && isSignedIn();
      allow read: if true;
    } 

  }
}

