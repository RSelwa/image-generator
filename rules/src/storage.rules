rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSignedInAdmin() {
      return isSignedIn() && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.rights == "admin";
    }

    // Game thumbnails - public read, admin write only
    match /game-thumbnails/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedInAdmin();
    }

    // Sphericals - public read, admin write only
    match /sphericals/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedInAdmin();
    }

    // Map thumbnails - public read, admin write only
    match /map-thumbnails/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedInAdmin();
    }

    // Deny all other paths
    match /{allPaths=**} {
      // Admin
      allow read, write: if isSignedInAdmin();

      allow read, write: if false;
    }
  }
}