rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // Game thumbnails - public read, auth create only (no overwrite)
    match /game-thumbnails/{allPaths=**} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Sphericals - public read, auth create only (no overwrite)
    match /sphericals/{allPaths=**} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Map thumbnails - public read, auth create only (no overwrite)
    match /map-thumbnails/{allPaths=**} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}