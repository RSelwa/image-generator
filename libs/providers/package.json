{
  "name": "@repo/providers",
  "description": "Providers of services for the monorepo",
  "version": "0.0.0",
  "type": "module",
  "files": ["dist"],
  "types": "./dist/index.d.ts",
  "exports": {
    "./db-refs": {
      "default": "./dist/db-refs.js",
      "types": "./dist/db-refs.js"
    },
    "./firebase": {
      "default": "./dist/firebase.js",
      "types": "./dist/firebase.js"
    }
  },
  "scripts": {
    "compile": "tsc --noEmit",
    "lint": "biome check",
    "check-circular": "madge --circular --extensions ts ./src --ts-config ./tsconfig.json",
    "build": "tsdown",
    "coverage": "vitest run --coverage",
    "clean": "del-cli dist isolate tsconfig.tsbuildinfo"
  },
  "license": "MIT",
  "dependencies": {
    "@opensearch-project/opensearch": "^3.5.1",
    "@repo/common": "workspace:*",
    "@repo/schemas": "workspace:*",
    "firebase": "^12.3.0",
    "firebase-admin": "^13.5.0",
    "firebase-functions": "^6.3.0",
    "stripe": "^9.16.0"
  },
  "devDependencies": {
    "@codecompose/typescript-config": "^2.2.0",
    "@types/node": "^22.10.10",
    "del-cli": "^7.0.0",
    "madge": "^8.0.0",
    "tsdown": "^0.15.6",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
