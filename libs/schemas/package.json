{
  "name": "@repo/schemas",
  "type": "module",
  "version": "1.0.0",
  "description": "Schemas used across the repo",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "compile": "tsc --noEmit",
    "lint": "biome check",
    "check-circular": "madge --circular --extensions ts ./src --ts-config ./tsconfig.json",
    "test": "vitest run --coverage",
    "clean": "del-cli dist isolate tsconfig.tsbuildinfo",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@firebase/firestore": "^4.10.0",
    "@repo/common": "workspace:*",
    "firebase": "^12.8.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@codecompose/typescript-config": "^2.2.0",
    "del-cli": "^7.0.0",
    "madge": "^8.0.0",
    "tsdown": "^0.15.6",
    "typescript": "^5.7.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
