{
  "name": "geo-gamer",
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.0",
  "description": "Monorepo for flim",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "compile": "turbo compile --continue",
    "lint": "eslint",
    "lint:errors": "eslint --quiet",
    "lint:fix": "eslint --fix",
    "check-circular": "turbo check-circular --continue",
    "emulators:test": "firebase emulators:start --only firestore,functions,storage,auth,database",
    "test:front-ui": "pnpm -F @repo/front e2e:ui",
    "build:front": "turbo run -F @repo/front build",
    "dev:front": "turbo run -F @repo/front dev",
    "storybook:front": "pnpm run -F @repo/front storybook",
    "build": "turbo run build",
    "create:function": "npx tsx cli/create-function.mts",
    "build:functions": "turbo run build --filter=@repo/http --filter=@repo/create-user-document --filter=@repo/create-party-doc --filter=@repo/listen-docs --filter=@repo/lobby-presence",
    "build:libs": "turbo run build --filter=@repo/providers --filter=@repo/schemas --filter=@repo/testing --filter=@repo/common && pnpm install",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "dev:server": "deno run --allow-all --env=./scripts/.env --config scripts/deno.json scripts/src/server/index.ts",
    "test": "turbo run test",
    "watch": "turbo watch build --filter=@repo/providers --filter=./functions/*",
    "deploy": "firebase deploy",
    "script": "deno run --allow-all --env=./scripts/.env --config scripts/deno.json",
    "build:create-party-doc": "turbo run build --filter=@repo/create-party-doc",
    "build:create-user-document": "turbo run build --filter=@repo/create-user-document",
    "build:listen-docs": "turbo run build --filter=@repo/listen-docs",
    "build:lobby-presence": "turbo run build --filter=@repo/lobby-presence"
  },
  "pnpm": {
    "overrides": {
      "reselect": "5.1.0"
    }
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.2.0",
    "@clack/prompts": "^0.11.0",
    "@eslint-react/eslint-plugin": "^2.7.2",
    "@next/eslint-plugin-next": "^16.1.6",
    "@types/node": "^22.10.10",
    "consola": "^3.4.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "firebase-tools-with-isolate": "14.16.0",
    "husky": "^9.1.7",
    "tsx": "^4.20.6",
    "turbo": "^2.5.8",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
