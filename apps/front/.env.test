# Client-side emulator hosts (NEXT_PUBLIC_ so Next.js exposes them to the browser)
NEXT_PUBLIC_EMULATOR=true
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=localhost:8080
NEXT_PUBLIC_AUTH_EMULATOR_HOST=http://localhost:9099
NEXT_PUBLIC_STORAGE_EMULATOR_HOST=localhost:9199
NEXT_PUBLIC_FUNCTIONS_EMULATOR_HOST=http://localhost:5001

# Server-side emulator hosts (for Firebase Admin SDK in API routes)
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# Firebase project config (fake API key is fine for emulators)
NEXT_PUBLIC_FIREBASE_API_KEY=fake-api-key
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tiktok-generator-fa261
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=79796269085
NEXT_PUBLIC_FIREBASE_APP_ID=1:79796269085:web:ddbaba42e1b190315c16f4
